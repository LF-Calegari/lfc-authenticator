# Copie para .env: cp .env.example .env
# Rede Docker: mesma rede externa dos demais serviços do ecossistema (ex.: Kurtto). Padrão: lfc_platform_network.
# EXTERNAL_NETWORK_NAME=lfc_platform_network
# Deve ser a mesma senha usada em appsettings.Development.json (dotnet run fora do Docker).
# Exigência Microsoft: maiúsculas, minúsculas, números e símbolos.
MSSQL_SA_PASSWORD=DevPassword123!

# Credenciais dos usuários base do sistema.
# Obrigatórias para o seed em Development/Production. Troque em produção.
DEFAULT_SYSTEM_USER_PASSWORD=toor
ADMIN_SYSTEM_USER_PASSWORD=admin
DEFAULT_USER_PASSWORD=default
