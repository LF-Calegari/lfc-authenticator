# Copie para .env: cp .env.example .env
# Rede Docker: mesma rede externa dos demais serviços do ecossistema. Padrão: lfc_platform_network.
# EXTERNAL_NETWORK_NAME=lfc_platform_network
# Senha do usuário PostgreSQL (POSTGRES_USER=auth no compose). Deve ser a mesma usada em appsettings.Development.json ao rodar fora do Docker.
POSTGRES_PASSWORD=DevPassword123!
POSTGRES_PORT=5432

# Credencial do usuário root (root@email.com.br).
# Obrigatória para o seed em Development/Production. Troque em produção.
DEFAULT_SYSTEM_USER_PASSWORD=toor
